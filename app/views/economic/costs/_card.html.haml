- campaign ||= current_campaign
- currency = Onoma::Currency.find(Preference[:currency])
.activity.active{style: "border-right-color: #{activity.color}"}
  - if %w[administering animal_farming plant_farming tool_maintaining processing wine_making vine_farming].include?(activity.family)
    = render "economic/costs/card_content/#{activity.family}", activity: activity, campaign: campaign, currency: currency, result: result
    = render "economic/costs/cost", currency: currency, result: result
  - else
    = render "economic/costs/card_content/default", activity: activity, campaign: campaign, currency: currency, result: result
